# ⚠️ FICHIER D'EXEMPLE POUR PRODUCTION
# Ne commite JAMAIS ce fichier avec de vraies valeurs !
# Copie ces variables dans Vercel Dashboard → Settings → Environment Variables

# ============================================
# APP CONFIGURATION
# ============================================
# ⚠️ IMPORTANT : Change cette URL pour la production
NEXT_PUBLIC_APP_URL=https://www.virtus-smartfit.com

# ============================================
# SUPABASE
# ============================================
# Trouve ces valeurs dans : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace_with_vapid_public_key
# Web Push server keys — the public key must be the same as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:notifications@your-domain.com
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-to-server scheduled jobs and signed Cal.com webhooks.
# Generate separate random values, store them only in your host dashboards.
CRON_SECRET=replace-with-a-long-random-value
CAL_WEBHOOK_SECRET=replace-with-a-long-random-value

# WHATSAPP CLOUD API (Meta)
# Configure the webhook URL as https://your-domain.com/api/webhooks/whatsapp.
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-value
WHATSAPP_APP_SECRET=replace-with-your-meta-app-secret
WHATSAPP_ACCESS_TOKEN=replace-with-a-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-your-whatsapp-phone-number-id
WHATSAPP_GRAPH_API_VERSION=vXX.X

# ============================================
# STRIPE (MODE LIVE - PRODUCTION)
# ============================================
# ⚠️ IMPORTANT : Utilise les clés LIVE (pas test) en production
# Trouve ces valeurs dans : Stripe Dashboard → Developers → API Keys (mode LIVE)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx

# Stripe Connect — Stripe Dashboard → Settings → Connect → Integration
STRIPE_CONNECT_CLIENT_ID=ca_xxxxx

# Webhook Secret (après avoir configuré le webhook)
# Trouve dans : Stripe Dashboard → Developers → Webhooks → Endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Webhook Secret coaching (endpoint séparé /api/stripe/coaching/webhook)
STRIPE_COACHING_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Price IDs (mode LIVE)
# Trouve dans : Stripe Dashboard → Products → Price ID
# ⚠️ IMPORTANT : Ces variables doivent être définies 2 fois :
#   1. Sans NEXT_PUBLIC_ (pour le serveur)
#   2. Avec NEXT_PUBLIC_ (pour le client)
STRIPE_PRICE_TIER1_RAPPORT=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TIER2_PROTOCOL=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TIER3_COACHING=price_xxxxxxxxxxxxxxxxxxxxx

# Variables NEXT_PUBLIC pour les composants client
NEXT_PUBLIC_STRIPE_PRICE_TIER1_RAPPORT=price_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_TIER2_PROTOCOL=price_xxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_TIER3_COACHING=price_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# SMTP — Namecheap Private Email
# ============================================
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=coach@stryvlab.com
SMTP_PASS=xxxxxxxxxxxxxxx

# ============================================
# ANTHROPIC (CLAUDE AI)
# ============================================
# Trouve dans : Anthropic Console → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# SECURITY TOKENS
# ============================================
# Génère avec : openssl rand -base64 32
# ⚠️ IMPORTANT : Génère des secrets DIFFÉRENTS pour chacun
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret interne pour les appels server-to-server (ex: POST /api/progression/evaluate)
# Génère avec : openssl rand -base64 32
INTERNAL_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SECURITY / INTERNAL DASHBOARDS
# ============================================
# Ancienne liste interne, conservée uniquement pendant la migration.
INTERNAL_PRODUCT_FEEDBACK_USER_IDS=uuid_1,uuid_2

# Source de vérité pour tout le hub interne (admin et équipe dev uniquement).
# Les UUID Supabase sont recommandés ; les e-mails sont pratiques pour une petite équipe.
# Si ces valeurs sont absentes, l'ancienne liste ci-dessus est utilisée sans élargir l'accès.
INTERNAL_OPS_USER_IDS=uuid_1,uuid_2
INTERNAL_OPS_EMAILS=admin@votre-domaine.com,dev@votre-domaine.com

# Email(s) recevant les alertes sécurité
INTERNAL_SECURITY_ALERT_TO=stryv.revolution@gmail.com
RESEND_FROM_EMAIL=security@votre-domaine.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Durcissement V2
# true = accès dashboard interne refusé si la session n'est pas MFA AAL2
INTERNAL_REQUIRE_AAL2=true

# Refuse l'accès si la dernière auth forte est trop ancienne (en minutes)
INTERNAL_REQUIRE_RECENT_AUTH_MINUTES=60

# Optionnel : liste blanche IP exacte pour les dashboards internes
INTERNAL_TRUSTED_IPS=1.2.3.4,5.6.7.8











# Destructive account purge remains disabled until a production dry-run is reviewed.
ACCOUNT_PURGE_ENABLED=false
